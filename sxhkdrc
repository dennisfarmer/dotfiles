#
# wm independent hotkeys
#

# terminal emulator
super + Return
	st -g=100x40

super + shift + Return
	tmux ls | grep scratch | grep attached && {tmux detach -s scratch} || {st -g=100x40 -e zsh -c 'tmux new-session -A -s scratch;'}

# program launcher
super + d
	dmenu_run

# make sxhkd reload its configuration files:
super + Escape
	notify-send --urgency=low "restarting sxhkd" & pkill -x sxhkd >/dev/null 2>&1 && sxhkd & >/dev/null 2>&1

