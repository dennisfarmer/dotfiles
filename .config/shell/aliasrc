#!/bin/sh

# Use neovim for vim if present.
[ -x "$(command -v nvim)" ] && alias vim="nvim" vimdiff="nvim -d"

# sdiff for side-by-side diff

# Use $XINITRC variable if file exists.
[ -f "$XINITRC" ] && alias startx="startx $XINITRC"

# sudo not required for some system commands
for command in mount umount sv pacman emerge poweroff updatedb su gparted ; do
	alias $command="sudo $command"
done; unset command

# General
if [[ 'uname' == "Darwin" ]]; then
    alias ls='ls -AG'
else {
	alias ls="ls -ahN --color=auto --group-directories-first"
	#alias ls="ls -hN --color=auto --group-directories-first"
    #alias ls='ls --all --almost-all --color -hN --group-directories-first'
}
fi
alias \
    grep="grep --color=auto" \
    mkdir='mkdir -pv' \
    wget='wget --no-hsts' \
	info='info --vi-keys' \
	diff="diff --color=auto --side-by-side" \
	diffs="diff --color=auto --side-by-side --suppress-common-lines" \
    view="$EDITOR -R" \
	cp="cp -iv" \
	mv="mv -iv" \
	rm="rm -vI" \
	bc="bc -ql" \
	yt="youtube-dl --add-metadata -i" \
	yta="yt -x -f bestaudio/best" \
	ytv="yt -f bestvideo+bestaudio/best" \
	ffmpeg="ffmpeg -hide_banner"

