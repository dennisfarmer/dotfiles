	#shutdown_index=$(($(echo $cmds | grep --line-number "shutdown" | head -n1 | awk -F: '{print $1}')))
	#if [[ shutdown_index -gt 0 ]]
	#then
		#cmds=$(echo "$(echo $cmds | head -n $shutdown_index | tail -n1)
#$(echo $cmds | head -n $(($shutdown_index-1)))
#$(echo $cmds | tail -n $(($(echo $cmds | wc -l) - $shutdown_index)))")
	#fi
#fi


#echo $cmds > $HOME/github/f2.txt

choice="$(echo "$cmds" | cut -d'	' -f 1 | dmenu)" || exit 1

eval "$(echo "$cmds" | grep "^$choice	" | cut -d '	' -f2-)"
