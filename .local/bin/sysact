case "$(readlink -f /sbin/init)" in
	*runit*) hib="sudo -A zzz" ;;
	*openrc*) reb="sudo -A openrc-shutdown -r 0"; shut="sudo -A openrc-shutdown -p 0" ;;
esac

pgrep -u $USER "\bawesome$" >/dev/null 2>&1 && wm="awesome" && prettywm="awesomewm" ||
	pgrep -u $USER "\bstartplasma-x11$" >/dev/null 2>&1 && wm="startplasma-x11" && prettywm="plasma" ||
	pgrep -u $USER "\bdwm$" >/dev/null 2>&1 && wm="dwm" && prettywm="dwm"
	#pgrep -u $USER "\bxfce4-session$" >/dev/null 2>&1 && wm="xfwm" && prettywm="xfce"



